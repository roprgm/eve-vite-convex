# Created by `convex dev`; used by the browser and eve persistence hook.
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Shared only by the eve hook and Convex; never expose this to Vite.
EVE_HOOK_SECRET=replace-with-a-long-random-value

# Used by eve's default Vercel AI Gateway provider.
AI_GATEWAY_API_KEY=your-ai-gateway-key
